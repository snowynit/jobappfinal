<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Title -->
            <TextView
                android:id="@+id/textView3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Create your account"
                android:textColor="#000000"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Set up your account to manage your business, communicate faster, and get better results."
                android:textColor="#555555"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/textView3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Section -->
            <TextView
                android:id="@+id/textView4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Basic Information"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Name -->
            <EditText
                android:id="@+id/Name"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Full Name *"
                android:inputType="textPersonName"
                android:textSize="18sp"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/textView4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Email -->
            <EditText
                android:id="@+id/Email"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Email *"
                android:inputType="textEmailAddress"
                android:textSize="18sp"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/Name"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Phone -->
            <EditText
                android:id="@+id/PhoneNumber"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Phone Number"
                android:inputType="phone"
                android:textSize="18sp"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/Email"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:id="@+id/info"
                android:layout_width="25dp"
                android:layout_height="30dp"
                android:layout_marginTop="323dp"
                android:layout_marginBottom="378dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/PhoneNumber"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@android:drawable/ic_menu_info_details" />

            <TextView
                android:id="@+id/information"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:background="#EAEAEA"
                android:padding="8dp"
                android:text="Needed for direct contact!"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="italic"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/PhoneNumber" />
            <!-- Show password -->



            <TextView
                android:id="@+id/ShowPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Password"
                android:textColor="#006CEF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/PhoneNumber"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Password -->
            <EditText
                android:id="@+id/Password"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Password *"
                android:inputType="textPassword"
                android:textSize="18sp"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/ShowPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Confirm Password -->
            <EditText
                android:id="@+id/ConfirmPassword"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:hint="Confirm Password *"
                android:inputType="textPassword"
                android:textSize="18sp"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/Password"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Error -->
            <TextView
                android:id="@+id/alert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ConfirmPassword" />

            <!-- Button -->
            <Button
                android:id="@+id/next"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="NEXT"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/color_change"
                android:layout_margin="24dp"
                app:cornerRadius="14dp"
                app:layout_constraintTop_toBottomOf="@id/alert"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>



        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
