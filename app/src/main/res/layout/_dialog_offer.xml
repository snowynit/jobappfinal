<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_popup_background"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Send Offer"
        android:textColor="@color/gray_900"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/offerCandidateName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="To: Candidate"
        android:textColor="@color/gray_600"
        android:textSize="13sp" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.App.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:hint="Role / position">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/offerJobTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_900" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.App.TextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="Message to candidate">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/offerMessageInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:minLines="3"
            android:textColor="@color/gray_900" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Your contact details will be shared with this candidate."
        android:textColor="@color/gray_500"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/offerCancelButton"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:backgroundTint="@color/gray_100"
            android:text="Cancel"
            android:textAllCaps="false"
            android:textColor="@color/gray_900" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/offerSendButton"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_marginStart="10dp"
            android:text="Send Offer" />
    </LinearLayout>
</LinearLayout>
