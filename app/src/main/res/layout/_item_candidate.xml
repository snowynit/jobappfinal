<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="#EEF1F6"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#EEF1F6"
                app:strokeWidth="1dp">

                <ImageView
                    android:id="@+id/candidateAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pfp"
                    android:contentDescription="@null" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/candidateName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Candidate"
                    android:textColor="@color/gray_900"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/candidatePay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Desired pay"
                    android:textColor="@color/emerald_600"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/candidateBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Short bio"
            android:textColor="@color/gray_600"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/candidateType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/chip_indigo_soft"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Any type"
                android:textColor="@color/indigo_600"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/candidateFields"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/chip_indigo_soft"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="No fields"
                android:textColor="@color/indigo_600"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/sendOfferButton"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="14dp"
            android:text="Send Offer" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
