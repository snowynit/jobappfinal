<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">
        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business Registration"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#000000"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="32dp"/>

        <!-- Business Details -->
        <TextView
            android:id="@+id/businessDetailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/businessName"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="Business Name"
            android:padding="12dp"
            android:textSize="20sp"
            app:layout_constraintTop_toBottomOf="@id/businessDetailsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/businessLocationLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business location"
            android:textColor="#374151"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/businessName"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/businessAddress"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:background="#F3F4F6"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:text="Location not selected"
            android:textColor="#374151"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/businessLocationLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/setBusinessLocationButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:backgroundTint="@color/blue_600"
            android:text="Pick on map"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/businessAddress"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="24dp"/>

        <!-- Contact Info -->
        <TextView
            android:id="@+id/contactInfoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Info"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/setBusinessLocationButton"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/businessEmail"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="Email"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/contactInfoTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/businessPhone"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="Phone number (optional)"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/businessEmail"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="24dp"/>

        <!-- Hiring Needs -->
        <TextView
            android:id="@+id/hiringNeedsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hiring Needs"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/businessPhone"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="16dp"/>

        <!-- Hiring buttons -->
        <LinearLayout
            android:id="@+id/hiringButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/hiringNeedsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="24dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/fulltime"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="Full-Time"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/halftime"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="Part-Time"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/temporary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="Temporary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Wage -->
        <TextView
            android:id="@+id/wageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wage"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            app:layout_constraintTop_toBottomOf="@id/hiringButtons"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:id="@+id/PayRateButtons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/wageTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="24dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/daily"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginRight="50dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="daily"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/hourly"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:text="hourly"
                android:textSize="12sp" />

        </LinearLayout>

        <EditText
            android:id="@+id/payrate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:hint="Hourly / Daily Pay"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/PayRateButtons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/confirm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="Confirm"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/blue_600"
            app:layout_constraintTop_toBottomOf="@id/payrate"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>



