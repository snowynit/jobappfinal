<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/indigo_600</item>
        <item name="colorPrimaryVariant">@color/indigo_600</item>
        <item name="colorSecondary">@color/blue_600</item>
    </style>

    <!-- ===== Window transitions ===== -->
    <style name="WindowAnimation.Fade" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_out</item>
    </style>

    <!-- ===== Buttons ===== -->
    <style name="Widget.App.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">22dp</item>
        <item name="android:paddingEnd">22dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/indigo_600</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="Widget.App.Button.Tonal" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/indigo_600</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/indigo_50</item>
        <item name="rippleColor">#1A4F46E5</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.App.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/indigo_600</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/indigo_600</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">#1A4F46E5</item>
    </style>

    <!-- ===== Cards ===== -->
    <style name="Widget.App.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeColor">#EEF1F6</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">18dp</item>
    </style>

    <style name="Widget.App.Card.Flat" parent="Widget.App.Card">
        <item name="cardElevation">0dp</item>
    </style>

    <!-- ===== Inputs ===== -->
    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/indigo_600</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/indigo_600</item>
        <item name="android:textColorHint">@color/gray_500</item>
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.TextInputEditText</item>
    </style>

    <style name="ThemeOverlay.App.TextInputEditText" parent="ThemeOverlay.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="colorPrimary">@color/indigo_600</item>
        <item name="colorOnSurface">@color/gray_900</item>
    </style>

    <!-- ===== Text appearances ===== -->
    <style name="TextAppearance.App.Display" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">@color/gray_900</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/gray_900</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/gray_600</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/gray_500</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ===== Legacy ===== -->
    <style name="filterButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">10dp</item>
        <item name="android:backgroundTint">@color/indigo_50</item>
        <item name="android:textColor">@color/indigo_600</item>
    </style>
</resources>
